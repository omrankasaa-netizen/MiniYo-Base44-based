# MiniYo backend environment — copy to .env for local dev, or set these in Railway → Variables.
# NEVER commit the real .env (it is git-ignored).

# Port the server listens on. Railway sets PORT automatically; leave unset there.
PORT=4000

# Path to the SQLite database file.
# On Railway: mount a persistent Volume (e.g. at /data) and set MINIYO_DB_PATH=/data/data.db
# so your products/orders survive redeploys. Locally you can leave this unset.
MINIYO_DB_PATH=/data/data.db

# Signing secret for auth (JWT) tokens. MUST be a long random value in production.
# If unset, the code falls back to a dev-only placeholder (not safe for prod).
MINIYO_JWT_SECRET=set-a-long-random-secret

# Initial super-admin password, seeded at first boot for admin@miniyo.store.
# Change it immediately after the first login.
MINIYO_ADMIN_PASSWORD=set-a-strong-password

# Resend transactional email
RESEND_API_KEY=your_resend_api_key_here
# Sender must be on a domain VERIFIED in Resend. mail.miniyokids.com is verified.
MINIYO_EMAIL_FROM=MiniYo <management@mail.miniyokids.com>

# ─── Product image storage (Cloudflare R2) ───────────────────────────────────
# When ALL of the required R2 vars below are set, product images upload to
# Cloudflare R2 (durable object storage) instead of the local /uploads disk.
# This fixes the Railway "dead photos after redeploy" problem (ephemeral disk).
# Leave them UNSET for local dev → images fall back to local disk under /uploads.
# See docs/IMAGES.md for the full setup walkthrough.
#
# Required (all must be present to enable R2):
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=miniyo-images
# Public base URL used to build <img> src links: either the bucket's public
# r2.dev URL or a Cloudflare custom domain mapped to the bucket. No trailing slash.
R2_PUBLIC_BASE_URL=https://images.miniyokids.com
# Optional: S3 API endpoint. Derived from R2_ACCOUNT_ID when omitted, i.e.
# https://<account_id>.r2.cloudflarestorage.com
# R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# ─── Meta (Facebook) Pixel + Conversions API ─────────────────────────────────
# The Pixel ID is PUBLIC (it ships in the client bundle). The CAPI access token
# is a SECRET — set it ONLY in Railway variables, never commit it, and it must
# never reach the client bundle or logs. See docs/META_TRACKING.md.
#
# Backend (server-side CAPI):
MINIYO_META_PIXEL_ID=1480243427454221
MINIYO_META_CAPI_ACCESS_TOKEN=your_meta_capi_access_token_here
# Optional — when set, events are routed to the Events Manager "Test Events" tab.
MINIYO_META_TEST_EVENT_CODE=
#
# Frontend (Vite): the public Pixel ID exposed to the client build. Defaults to
# the value baked into index.html when unset.
VITE_META_PIXEL_ID=1480243427454221

# ─── TikTok Pixel + Events API ───────────────────────────────────────────────
# Installed ALONGSIDE Meta (never replacing it). The Pixel ID is PUBLIC (it ships
# in the client bundle). The Events API access token is a SECRET — set it ONLY in
# Railway variables, never commit it, and it must never reach the client bundle
# or logs. When the token is unset the server-side sender silently no-ops (never
# throws, never hits the network), exactly like the Meta CAPI token.
#
# Backend (server-side Events API):
MINIYO_TIKTOK_PIXEL_ID=D9BP18JC77U1026616UG
# SECRET — leave blank until you paste the real token into Railway. Server TikTok
# events stay disabled (no-op) until this is set.
MINIYO_TIKTOK_ACCESS_TOKEN=
# Optional — when set, events are routed to the TikTok Events Manager "Test
# Events" tab. Leave unset in production.
MINIYO_TIKTOK_TEST_EVENT_CODE=
#
# Frontend (Vite): the public TikTok Pixel ID exposed to the client build.
# Defaults to the value baked into index.html when unset.
VITE_TIKTOK_PIXEL_ID=D9BP18JC77U1026616UG
