      "type": "string",
      "description": "Link to Product"
    },
    "url": {
      "type": "string"
    },
    "alt": {
      "type": "string"
    },
    "alt_ar": {
      "type": "string"
    },
    "is_primary": {
      "type": "boolean",
      "default": false
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
