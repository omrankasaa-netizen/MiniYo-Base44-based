# MiniYo backend environment — copy to .env for local dev, or set these in Railway → Variables.
# NEVER commit the real .env (it is git-ignored).

# Port the server listens on. Railway sets PORT automatically; leave unset there.
PORT=4000

# Path to the SQLite database file.
# On Railway: mount a persistent Volume (e.g. at /data) and set MINIYO_DB_PATH=/data/data.db
# so your products/orders survive redeploys. Locally you can leave this unset.
MINIYO_DB_PATH=/data/data.db

# Resend transactional email
RESEND_API_KEY=your_resend_api_key_here
# Sender must be on a domain VERIFIED in Resend. mail.miniyokids.com is verified.
MINIYO_EMAIL_FROM=MiniYo <management@mail.miniyokids.com>
